PORT=4173
PROXY_TIMEOUT_MS=30000
GATEWAY_ORIGIN=http://127.0.0.1:4173

# Optional: only needed if you want /api/state proxying enabled.
BACKEND_URL=

# Polaris REST catalog connection used by the local backend.
# This app queries Polaris directly via server/polaris_duckdb.py (DuckDB + PyIceberg).
POLARIS_CLIENT_ID=
POLARIS_CLIENT_SECRET=
POLARIS_OAUTH_URI=https://YOUR_TENANT.atlan.com/api/polaris/api/catalog/v1/oauth/tokens
POLARIS_ENDPOINT=https://YOUR_TENANT.atlan.com/api/polaris/api/catalog
CATALOG_NAME=atlan-wh
GOLD_NAMESPACE=atlan-ns
POLARIS_ROLE_NAME=ALL

# Optional S3/Iceberg environment passthrough when required by your setup.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# Optional direct Atlan API passthrough for /api/atlan/*
ATLAN_BASE_URL=https://YOUR_TENANT.atlan.com
ATLAN_API_KEY=
